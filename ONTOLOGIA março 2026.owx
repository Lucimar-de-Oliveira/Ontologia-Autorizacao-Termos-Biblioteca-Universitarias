    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:definition"/>
        <IRI>/TesauroSobreLiteratura</IRI>
        <Literal>Tesauro em literatura do IBICT.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/Tesauros</IRI>
        <Literal>CUNHA, Murilo Bastos da; CAVALCANTI, Cordélia Robalinho de Oliveira. Dicionário de
biblioteconomia e arquivologia. Brasília: Briquet de Lemos, 2008.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/Tesauros</IRI>
        <Literal>http://repositorio.unb.br/handle/10482/34113</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/Tesauros</IRI>
        <Literal>https://vocabularyserver.com/brased/</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>/Tesauros</IRI>
        <Literal>Tesauros</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:altLabel"/>
        <IRI>/Tesauros</IRI>
        <Literal>Thesaurus</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:definition"/>
        <IRI>/Tesauros</IRI>
        <Literal>Tesauro / Thesaurus (plural: thesauri)
Tesauro é um vocabulário controlado e dinâmico, composto por termos normalizados e organizados conceitualmente, ligados por relações semânticas, hierárquicas, associativas e de equivalência, utilizado para traduzir a linguagem natural em linguagem documentária e apoiar os processos de indexação e recuperação da informação. Cunha (2008, p.362)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:example"/>
        <IRI>/Tesauros</IRI>
        <Literal>Thesaurus Brasileiro da Educação.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:scopeNote"/>
        <IRI>/Tesauros</IRI>
        <Literal>Dicionário de Biblioteconomia e Arquivologia</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/TesaurosDeCienciasDaSaude</IRI>
        <Literal>DECS Descritores em Ciências da Saúde/MeSH – Medical Subject Headings</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/TesaurosDeCienciasDaSaude</IRI>
        <Literal>https://decs.bvsalud.org/sobre-o-decs/</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:definition"/>
        <IRI>/TesaurosDeCienciasDaSaude</IRI>
        <Literal>Descritores em Ciências da Saúde/Medical Subject Headings é um vocabulário estruturado criado pela BIREME em 1986 para servir como linguagem única na indexação de artigos de revistas científicas, livros, anais de congressos, relatórios técnicos, e outros tipos de documentos, assim como para ser usado na pesquisa e recuperação de assuntos da literatura científica nas fontes de informação disponíveis na Biblioteca Virtual em Saúde (BVS) como LILACS, MEDLINE e outras.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:prefLabel"/>
        <IRI>/TesaurosDeCienciasDaSaude</IRI>
        <Literal>Tesauros De Ciências da Saúde</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/ThesBio</IRI>
        <Literal>THESBIO: thesaurus em biodiversidade. São Paulo: Rede BHL SciELO.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/ThesBio</IRI>
        <Literal>http://thesaurus.bhlscielo.org/vocab/index.php?tema=87</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:definition"/>
        <IRI>/ThesBio</IRI>
        <Literal>Tesauro na área de Ciência Ambientais.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
