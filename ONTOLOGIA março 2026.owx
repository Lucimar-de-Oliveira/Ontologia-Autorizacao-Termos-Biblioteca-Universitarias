        <Literal>Base de dados na área de educação</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/TesauroEric</IRI>
        <Literal>UNITED STATES. Department of Education. Institute of Education Sciences (IES). ERIC: Education Resources Information Center. Washington, DC.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>/TesauroEric</IRI>
        <Literal>https://eric.ed.gov/?note</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:definition"/>
        <IRI>/TesauroEric</IRI>
        <Literal>ERIC (Education Resources Information Center) vocabulário na área de educação, e um sistema de informação e base de dados bibliográfica especializada na área da Educação, mantido pelo Departamento de Educação dos Estados Unidos, que reúne, organiza, indexa e disponibiliza literatura educacional, incluindo artigos de periódicos, relatórios técnicos, documentos institucionais e outros materiais relevantes para pesquisa, ensino e formulação de políticas públicas.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:prefLabel"/>
        <IRI>/TesauroEric</IRI>
        <Literal>Eric - Education Resources Information Center</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
