        <IRI>/EstruturaDoTermo</IRI>
        <Literal>https://files.cercomp.ufg.br/weby/up/88/o/Manual_Politica_SIBi_UFG.pdf</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
